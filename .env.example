# Token para verificar el webhook de WhatsApp (el que pones en Meta)
VERIFY_TOKEN=

# IA: este flujo usa Claude
CLAUDE_API_KEY=

# WhatsApp Business API (Meta for Developers)
# Los números que pueden RECIBIR mensajes se configuran en Meta (API Setup → "A" / lista de destinatarios).
# Aquí solo va el token y el ID del número desde el que envías.
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=

# Para test local (test-chat-local.js): debe ser uno de los números que tienes en la lista de Meta.
# Ejemplo Chile: 56912345678 (sin +). Sin esto, el script usa 17863559966 y Meta rechaza (no está en la lista).
TEST_FROM=
